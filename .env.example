# OpenAI API key for AI stat projections (required for npm run ai-project)
OPENAI_API_KEY=sk-your-key-here

# Model (default: gpt-4o-mini). Use gpt-4o for higher quality.
# OPENAI_MODEL=gpt-4o

# Limit AI projection batch size (useful for testing)
# AI_LIMIT=50

# Force re-project all cached players
# AI_FORCE=1

# Yahoo Fantasy API (for position eligibility — https://developer.yahoo.com/apps/)
# YAHOO_CLIENT_ID=your-client-id
# YAHOO_CLIENT_SECRET=your-client-secret
# YAHOO_REDIRECT_URI=oob
