# All variables are optional — the committed data lets the site build with no keys.

# Yahoo Fantasy API (position eligibility — https://developer.yahoo.com/apps/)
# YAHOO_CLIENT_ID=your-client-id
# YAHOO_CLIENT_SECRET=your-client-secret
# YAHOO_REDIRECT_URI=oob

# OpenAI (only for the optional npm run ai-project engine)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o
# AI_LIMIT=50
# AI_FORCE=1

# Limit dossier collection batch size (testing)
# PROFILE_LIMIT=30
